# GEMINI_API_KEY: Required for Gemini AI API calls on the server.
# AI Studio automatically injects this at runtime.
# This variable name is RESERVED in AI Studio.
GEMINI_API_KEY="RESERVED_IN_AI_STUDIO"

# VITE_GEMINI_API_KEY: Use this if you are deploying to Netlify/Vercel 
# without an Express backend, to enable client-side AI calls.
VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
