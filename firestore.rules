rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.2 Public test connection
    match /test/connection {
      allow read: if true;
    }

    // 0.3 Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isSuperAdmin() { return isSignedIn() && request.auth.token.email == 'abrahamsande256@gmail.com'; }
    // Hardened check to avoid runtime errors on missing documents
    function isAdmin() { 
      return isSignedIn() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'customer') == 'admin')
      ); 
    }
    
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. User Profiles
    match /users/{uid} {
      function isValidUser(data) {
        return data.uid == uid &&
               data.email is string &&
               data.role in ['customer', 'rider', 'admin'] &&
               data.isApproved is bool;
      }

      allow get: if isSignedIn();
      
      // Pillar 8: Security boundaries enforced by resource evaluation
      allow list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.role == 'rider' && resource.data.isApproved == true) ||
        resource.data.role == 'admin'
      );
      
      allow create: if isOwner(uid) && isValidUser(incoming());

      allow update: if (isOwner(uid) && (
        // Action: Rider toggles, Profile Updates, or Application Status
        (incoming().diff(existing()).affectedKeys().hasAny(['isOnline', 'lastKnownLocation', 'lastLocationUpdate', 'isOnTrip', 'displayName', 'phoneNumber', 'bikeType', 'numberPlate', 'fuelConsumptionRate', 'tankCapacity', 'earnings', 'walletBalance', 'status', 'role_requested', 'verification_status']))
      )) || (isSignedIn() && (
        // Action: Wallet/Earnings updates during rides (POC allowance)
        (incoming().diff(existing()).affectedKeys().hasAny(['walletBalance', 'earnings', 'isOnline', 'lastKnownLocation', 'lastLocationUpdate', 'isOnTrip']))
      )) || isAdmin();

      allow delete: if isAdmin();
    }

    // 2.1 Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 2.2 Rider Applications
    match /rider_applications/{appId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Ride Requests
    match /rides/{rideId} {
      function isValidRide(data) {
        return data.customerId is string && 
               data.status in ['REQUESTED', 'ACCEPTED', 'ARRIVED', 'TRIP_STARTED', 'COMPLETED', 'CANCELLED'];
      }

      // Pillar 8: List explicitly evaluates resource.data
      allow list: if isAdmin() || (
        isSignedIn() && (
          resource.data.customerId == request.auth.uid || 
          resource.data.riderId == request.auth.uid ||
          resource.data.status == 'REQUESTED'
        )
      );
      
      allow get: if isAdmin() || 
                    (isSignedIn() && (
                      resource.data.customerId == request.auth.uid || 
                      resource.data.riderId == request.auth.uid
                    ));
      
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid && isValidRide(incoming());

      allow update: if (
        isAdmin() || 
        // Accept logic (Rider joining)
        (isSignedIn() && existing().status == 'REQUESTED' && incoming().status == 'ACCEPTED' && 
         incoming().diff(existing()).affectedKeys().hasAny(['riderId', 'status', 'riderName', 'riderPhone'])) ||
        // Progress logic (Owner or Rider assigned)
        ((resource.data.customerId == request.auth.uid || resource.data.riderId == request.auth.uid) && 
         incoming().diff(existing()).affectedKeys().hasAny(['status'])) ||
        // Cancel logic
        (resource.data.customerId == request.auth.uid && incoming().status == 'CANCELLED')
      );
    }

    // 4. Trip History (Logs)
    match /trips/{tripId} {
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
  }
}
