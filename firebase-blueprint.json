export async function getDestinationSuggestions(
  input: string,
  currentLocation: GeoLocation | null
): Promise<string[]> {
  if (!input || input.length < 2) return [];
  
  const cacheKey = input.toLowerCase().trim();
  if (suggestionCache[cacheKey]) return suggestionCache[cacheKey];
  
  try {
    const locationString = currentLocation ? `${currentLocation.latitude}, ${currentLocation.longitude}` : "Kampala Central";
    
    const response = await callGeminiProxy(
      `As an expert Kampala navigator, suggest 5 specific destination names and locations in Kampala starting with or related to "${input}". Include landmarks or major roads if relevant. Current context location: ${locationString}. Provide only the names of the places.`,
      {
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            suggestions: {
              type: Type.ARRAY,
              items: { type: Type.STRING }
            }
          },
          required: ["suggestions"]
        }
      }
    );

    const result = JSON.parse(response.text || "{}");
    const suggestions = result.suggestions || KAMPALA_FALLBACK_SUGGESTIONS.filter(s => s.toLowerCase().includes(input.toLowerCase()));
    
    if (result.suggestions && result.suggestions.length > 0) {
      suggestionCache[cacheKey] = suggestions;
    }
    return suggestions;
  } catch (error) {
    return KAMPALA_FALLBACK_SUGGESTIONS.filter(s => s.toLowerCase().includes(input.toLowerCase()));
  }
}

export async function getRouteOptimization(
  start: string,
  end: string,
  rider: Rider,
  options: {
    fuelPrice?: number;
    demandLevel?: 'low' | 'normal' | 'high';
    timeOfDay?: string;
  } = {}
): Promise<RouteOptimizationResult> {
  const { fuelPrice = 9200, demandLevel = 'normal', timeOfDay = new Date().toLocaleTimeString() } = options;
  
  const cacheKey = `${start}-${end}`.toLowerCase().trim();
  if (routeCache[cacheKey]) return routeCache[cacheKey];
  
  try {
    const response = await callGeminiProxy(
      `
        You are the '2026 Kampala Boda-Boda Route Master'. Maximize rider profit for a trip:
        - Origin: "${start}"
        - Destination: "${end}"
        - Context: 2026 high fuel cost (${fuelPrice} UGX), heavy "Kampala Jam", and the 7 Hills terrain.
        - Consideration: Idling in traffic and high-RPM climbing on hills like Kololo or Old Kampala cost significantly more fuel.
        
        Route 1 (Best Fuel): Flat terrain, avoid jam, minimize idling.
        Route 2 (Alternative): fastest but potentially higher fuel/hill demand.
      `,
      {
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            suggestions: { type: Type.ARRAY, items: { type: Type.STRING } },
            best_route: {
              type: Type.OBJECT,
              properties: {
                description: { type: Type.STRING },
                fuel_litres: { type: Type.NUMBER },
                cost: { type: Type.NUMBER },
                time_minutes: { type: Type.NUMBER },
                distance: { type: Type.NUMBER },
                via_road: { type: Type.STRING },
                traffic_level: { type: Type.STRING },
                reason: { type: Type.STRING },
                profit_saved: { type: Type.NUMBER },
                suggested_fare_range: {
                  type: Type.OBJECT,
                  properties: { min: { type: Type.NUMBER }, max: { type: Type.NUMBER } },
                  required: ["min", "max"]
                },
                waypoints: {
                  type: Type.ARRAY,
                  items: { type: Type.ARRAY, items: { type: Type.NUMBER } }
                }
              },
              required: ["description", "fuel_litres", "cost", "time_minutes", "distance", "reason", "waypoints", "suggested_fare_range"]
            },
            alternative_routes: {
              type: Type.ARRAY,
              items: {
                type: Type.OBJECT,
                properties: {
                  description: { type: Type.STRING },
                  fuel_litres: { type: Type.NUMBER },
                  cost: { type: Type.NUMBER },
                  time_minutes: { type: Type.NUMBER },
                  distance: { type: Type.NUMBER },
                  reason: { type: Type.STRING },
                  waypoints: {
                    type: Type.ARRAY,
                    items: { type: Type.ARRAY, items: { type: Type.NUMBER } }
                  },
                  suggested_fare_range: {
                    type: Type.OBJECT,
                    properties: { min: { type: Type.NUMBER }, max: { type: Type.NUMBER } },
                    required: ["min", "max"]
                  }
                },
                required: ["description", "fuel_litres", "cost", "time_minutes", "distance", "reason", "waypoints", "suggested_fare_range"]
              }
            },
            navigation_steps: { type: Type.ARRAY, items: { type: Type.STRING } },
            distance: { type: Type.NUMBER }
          },
          required: ["suggestions", "best_route", "alternative_routes", "navigation_steps", "distance"]
        }
      }
    );

    const rawResult = JSON.parse(response.text || "{}");
    const result = {
      ...rawResult,
      distance: rawResult.best_route.distance || rawResult.distance || 0
    };
    
    routeCache[cacheKey] = result;
    return result;
  } catch (error) {
    console.error("Gemini Error (Route Optimization):", error);
    // Generic fallback implementation...
    const baseDist = Math.max(3, (end.length % 10) + 2); 
    return {
      suggestions: [end],
      best_route: {
        description: `AI Fuel Saver Route`,
        fuel_litres: baseDist * 0.035,
        cost: Math.round(baseDist * 1800),
        time_minutes: Math.round(baseDist * 4),
        distance: baseDist,
        via_road: "Back Roads & Flat Paths",
        traffic_level: "Low",
        reason: "Primary choice to avoid hill climbing and idling.",
        waypoints: [[0.2983, 32.6015], [0.3015, 32.6035], [0.2975, 32.5970]],
        suggested_fare_range: { min: 4000, max: 8000 }
      },
      alternative_routes: [],
      navigation_steps: ["Start", "Avoid main road", "Arrive"],
      distance: baseDist
    };
  }
}

export async function getSmartSuggestions(trips: any[]): Promise<string[]> {
  try {
    const response = await callGeminiProxy(
      `Analyze these recent trips for a boda-boda rider in Kampala and provide 3 actionable profit/fuel suggestions: ${JSON.stringify(trips)}`,
      {
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            suggestions: {
              type: Type.ARRAY,
              items: { type: Type.STRING }
            }
          },
          required: ["suggestions"]
        }
      }
    );

    const result = JSON.parse(response.text || "{}");
    return result.suggestions || ["Minimize idling at Jinja Rd lights", "Shift gears early on hill climbs"];
  } catch (error) {
    return ["Avoid high revving", "Plan rest breaks outside peak jam hours"];
  }
}

