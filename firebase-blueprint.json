import { Rider, RouteOptimizationResult, GeoLocation, TrafficAlert, FuelPriceAlert, Type } from "../types";

// Helper to call our secure server-side proxy
async function callGeminiProxy(contents: any, config?: any, model: string = "gemini-3-flash-preview") {
  try {
    const response = await fetch('/api/gemini', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ contents, config, model }),
    });

    if (!response.ok) {
      const errorData = await response.json();
      throw new Error(errorData.error || `Server responded with ${response.status}`);
    }

    const data = await response.json();
    return data; // contains { text: "..." }
  } catch (error: any) {
    console.error("Gemini Proxy Call Failed:", error);
    return { text: "{}" };
  }
}

